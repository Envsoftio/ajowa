{{> header title=title eyebrow="Service Request" subtitle="There is an update on your service request."}}

<p style="margin: 0 0 18px; color: #52606d; font-size: 15px; line-height: 1.7;">
  Hello,
</p>
<p style="margin: 0 0 20px; color: #52606d; font-size: 15px; line-height: 1.7;">
  {{body}}
</p>

<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin: 24px 0; border: 1px solid #d9e5e2; border-radius: 8px; background: #f8fbfa;">
  {{#if ticketNumber}}
    <tr>
      <td style="padding: 12px 22px; color: #607080; font-size: 13px;">Ticket</td>
      <td align="right" style="padding: 12px 22px; color: #102033; font-size: 14px; font-weight: 700;">{{ticketNumber}}</td>
    </tr>
  {{/if}}
  {{#unless ticketNumber}}
    {{#if requestNumber}}
      <tr>
        <td style="padding: 12px 22px; color: #607080; font-size: 13px;">Request</td>
        <td align="right" style="padding: 12px 22px; color: #102033; font-size: 14px; font-weight: 700;">{{requestNumber}}</td>
      </tr>
    {{/if}}
  {{/unless}}
  {{#if status}}
    <tr>
      <td style="padding: 12px 22px; border-top: 1px solid #d9e5e2; color: #607080; font-size: 13px;">Status</td>
      <td align="right" style="padding: 12px 22px; border-top: 1px solid #d9e5e2; color: #102033; font-size: 14px; font-weight: 700;">{{status}}</td>
    </tr>
  {{/if}}
  {{#if ticketTitle}}
    <tr>
      <td style="padding: 12px 22px; border-top: 1px solid #d9e5e2; color: #607080; font-size: 13px;">Subject</td>
      <td align="right" style="padding: 12px 22px; border-top: 1px solid #d9e5e2; color: #102033; font-size: 14px; font-weight: 700;">{{ticketTitle}}</td>
    </tr>
  {{/if}}
</table>

{{#if actionUrl}}
  <p style="margin: 28px 0 0;">
    <a
      href="{{actionUrl}}"
      style="display: inline-block; padding: 14px 22px; border-radius: 8px; background: #0f766e; color: #ffffff; font-size: 14px; font-weight: 700; text-decoration: none;"
    >
      {{#if actionLabel}}{{actionLabel}}{{else}}Open in AJOWA{{/if}}
    </a>
  </p>
{{/if}}

{{> footer}}
