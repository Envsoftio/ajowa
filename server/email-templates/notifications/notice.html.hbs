{{> header title=title eyebrow="Society Notice" subtitle="A new notice has been published for your society."}}

<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin: 0 0 24px; border: 1px solid #d9e5e2; border-radius: 8px; background: #f8fbfa;">
  <tr>
    <td style="padding: 18px 20px;">
      <p style="margin: 0; color: #102033; font-size: 15px; line-height: 1.7;">
        {{body}}
      </p>
    </td>
  </tr>
</table>

<p style="margin: 0 0 22px; color: #52606d; font-size: 14px; line-height: 1.7;">
  Open AJOWA to read the full notice, view attachments if available, and mark it as read.
</p>

{{#if actionUrl}}
  <p style="margin: 28px 0 0;">
    <a
      href="{{actionUrl}}"
      style="display: inline-block; padding: 14px 22px; border-radius: 8px; background: #0f766e; color: #ffffff; font-size: 14px; font-weight: 700; text-decoration: none;"
    >
      {{#if actionLabel}}{{actionLabel}}{{else}}Open in AJOWA{{/if}}
    </a>
  </p>
{{/if}}

{{> footer}}
