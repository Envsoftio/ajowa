{{> header title=title eyebrow="Payment Overdue" accentColor="#b42318" subtitle="This maintenance due is past its due date."}}

<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin: 0 0 22px; border: 1px solid #fecaca; border-radius: 8px; background: #fff5f5;">
  <tr>
    <td style="padding: 16px 18px;">
      <p style="margin: 0; color: #7f1d1d; font-size: 15px; font-weight: 700; line-height: 1.6;">
        {{body}}
      </p>
    </td>
  </tr>
</table>

<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin: 24px 0; border: 1px solid #fecaca; border-radius: 8px; background: #fffafa;">
  {{#if balanceAmount}}
    <tr>
      <td colspan="2" style="padding: 20px 22px 14px;">
        <p style="margin: 0 0 6px; color: #991b1b; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;">
          Overdue amount
        </p>
        <p style="margin: 0; color: #b42318; font-size: 28px; font-weight: 700; line-height: 1.2;">
          &#8377;{{balanceAmount}}
        </p>
      </td>
    </tr>
  {{/if}}
  {{#if flatLabel}}
    <tr>
      <td style="padding: 12px 22px; border-top: 1px solid #fecaca; color: #7f1d1d; font-size: 13px;">Flat</td>
      <td align="right" style="padding: 12px 22px; border-top: 1px solid #fecaca; color: #102033; font-size: 14px; font-weight: 700;">{{flatLabel}}</td>
    </tr>
  {{/if}}
  {{#if billingPeriodLabel}}
    <tr>
      <td style="padding: 12px 22px; border-top: 1px solid #fecaca; color: #7f1d1d; font-size: 13px;">Billing period</td>
      <td align="right" style="padding: 12px 22px; border-top: 1px solid #fecaca; color: #102033; font-size: 14px; font-weight: 700;">{{billingPeriodLabel}}</td>
    </tr>
  {{/if}}
  {{#if dueDate}}
    <tr>
      <td style="padding: 12px 22px; border-top: 1px solid #fecaca; color: #7f1d1d; font-size: 13px;">Due date</td>
      <td align="right" style="padding: 12px 22px; border-top: 1px solid #fecaca; color: #102033; font-size: 14px; font-weight: 700;">{{dueDate}}</td>
    </tr>
  {{/if}}
</table>

<p style="margin: 0 0 22px; color: #52606d; font-size: 14px; line-height: 1.7;">
  A PDF copy of the bill is attached for your records. Please complete the payment at the earliest to avoid service interruptions or additional follow-up from the society office.
</p>

{{#if actionUrl}}
  <p style="margin: 28px 0 0;">
    <a
      href="{{actionUrl}}"
      style="display: inline-block; padding: 14px 22px; border-radius: 8px; background: #b42318; color: #ffffff; font-size: 14px; font-weight: 700; text-decoration: none;"
    >
      {{#if actionLabel}}{{actionLabel}}{{else}}Open in AJOWA{{/if}}
    </a>
  </p>
{{/if}}

{{> footer}}
