{{> header title=title eyebrow="Gate Access" subtitle="Your visitor and gate access status has been updated."}}

<p style="margin: 0 0 18px; color: #52606d; font-size: 15px; line-height: 1.7;">
  Hello,
</p>
<p style="margin: 0 0 20px; color: #52606d; font-size: 15px; line-height: 1.7;">
  {{body}}
</p>

<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin: 24px 0; border: 1px solid #bbf7d0; border-radius: 8px; background: #f0fdf4;">
  <tr>
    <td style="padding: 16px 18px;">
      <p style="margin: 0 0 6px; color: #166534; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;">
        Access active
      </p>
      <p style="margin: 0; color: #14532d; font-size: 14px; line-height: 1.7;">
        Open AJOWA on your phone to view the latest gate QR before visiting the entry point.
      </p>
    </td>
  </tr>
</table>

{{#if actionUrl}}
  <p style="margin: 28px 0 0;">
    <a
      href="{{actionUrl}}"
      style="display: inline-block; padding: 14px 22px; border-radius: 8px; background: #0f766e; color: #ffffff; font-size: 14px; font-weight: 700; text-decoration: none;"
    >
      {{#if actionLabel}}{{actionLabel}}{{else}}Open in AJOWA{{/if}}
    </a>
  </p>
{{/if}}

{{> footer}}
