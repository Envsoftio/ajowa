{{> header title=title eyebrow="AJOWA Invite" subtitle="You have been invited to join your society workspace."}}

<p style="margin: 0 0 16px; color: #52606d; font-size: 15px; line-height: 1.7;">
  Hi {{name}},
</p>
<p style="margin: 0 0 16px; color: #52606d; font-size: 15px; line-height: 1.7;">
  {{inviterName}} invited you to join AJOWA as {{roleLabel}}.
</p>

<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin: 22px 0; border: 1px solid #d9e5e2; border-radius: 8px; background: #f8fbfa;">
  <tr>
    <td style="padding: 16px 18px;">
      <p style="margin: 0 0 6px; color: #607080; font-size: 12px; font-weight: 700; letter-spacing: 0.12em; text-transform: uppercase;">
        Access details
      </p>
      <p style="margin: 0; color: #102033; font-size: 14px; line-height: 1.6;">
        {{details}}
      </p>
    </td>
  </tr>
</table>

<p style="margin: 28px 0 20px;">
  <a
    href="{{actionUrl}}"
    style="display: inline-block; padding: 14px 22px; border-radius: 8px; background: #f59e0b; color: #102033; font-size: 14px; font-weight: 700; text-decoration: none;"
  >
    Accept Invite
  </a>
</p>

<p style="margin: 0; color: #52606d; font-size: 13px; line-height: 1.6;">
  This invite expires on {{expiresLabel}}. Accept it before then to activate your AJOWA access.
</p>

{{> footer}}
