<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin: 0 0 28px;">
  <tr>
    <td>
      <p style="margin: 0 0 8px; color: {{#if accentColor}}{{accentColor}}{{else}}#0f766e{{/if}}; font-size: 12px; font-weight: 700; letter-spacing: 0.14em; line-height: 1.4; text-transform: uppercase;">
        {{#if eyebrow}}{{eyebrow}}{{else}}AJOWA Society{{/if}}
      </p>
      <h1 style="margin: 0; color: #102033; font-size: 28px; font-weight: 700; line-height: 1.18;">
        {{title}}
      </h1>
      {{#if subtitle}}
        <p style="margin: 12px 0 0; color: #52606d; font-size: 15px; line-height: 1.6;">
          {{subtitle}}
        </p>
      {{/if}}
    </td>
  </tr>
</table>
