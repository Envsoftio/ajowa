{{> header title=title eyebrow="Account Security" subtitle="Use the secure link below to choose a new AJOWA password."}}

<p style="margin: 0 0 16px; color: #52606d; font-size: 15px; line-height: 1.7;">
  Hi {{name}},
</p>
<p style="margin: 0 0 20px; color: #52606d; font-size: 15px; line-height: 1.7;">
  We received a request to reset your AJOWA password. This link can be used once and should not be shared with anyone.
</p>

<p style="margin: 28px 0 20px;">
  <a
    href="{{actionUrl}}"
    style="display: inline-block; padding: 14px 22px; border-radius: 8px; background: #102033; color: #ffffff; font-size: 14px; font-weight: 700; text-decoration: none;"
  >
    Reset Password
  </a>
</p>

<table width="100%" cellpadding="0" cellspacing="0" role="presentation" style="margin: 22px 0 0; border: 1px solid #d9e5e2; border-radius: 8px; background: #f8fbfa;">
  <tr>
    <td style="padding: 14px 18px; color: #52606d; font-size: 13px; line-height: 1.6;">
      This link expires on {{expiresLabel}}. If you did not request this, you can safely ignore this email.
    </td>
  </tr>
</table>

<p style="margin: 18px 0 0; color: #7a8694; font-size: 12px; line-height: 1.6;">
  If the button does not work, open this link in your browser: <a href="{{actionUrl}}" style="color: #0f766e; text-decoration: underline;">{{actionUrl}}</a>
</p>

{{> footer}}
