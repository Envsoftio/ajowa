NUXT_PUBLIC_APP_NAME=AJOWA
NUXT_PUBLIC_APP_URL=https://ajowa.in
# The app standardizes on NUXT_PUBLIC_* values and also accepts
# SUPABASE_URL / SUPABASE_ANON_KEY as local compatibility aliases.
NUXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NUXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NUXT_PUBLIC_SOCIETY_CODE=AJOWA
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres?sslmode=disable
# Netlify/serverless production should use the Supabase Shared Pooler
# transaction URL on port 6543, not db.<project-ref>.supabase.co:5432
# unless the project has Supabase's IPv4 add-on.
# DATABASE_URL=postgresql://postgres.<project-ref>:<db-password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require
DB_POOL_MAX=1
DB_CONNECTION_TIMEOUT_MS=10000
DB_IDLE_TIMEOUT_MS=10000
# Optional DB backup settings for scripts/backup-prod-db.sh.
# PROD_BACKUP_DATABASE_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# BACKUP_ROOT=~/ajowa-prod-backups
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
BETTER_AUTH_SECRET=replace-with-a-long-random-secret
BETTER_AUTH_URL=https://ajowa.in

SMTP_PASS=

# Notification jobs are queued by producers and sent only from the admin
# notification process action. Automatic worker settings are legacy/no-op.
NOTIFICATION_WORKER_ENABLED=false
# NOTIFICATION_WORKER_INTERVAL_MS=30000
# NOTIFICATION_WORKER_BATCH_SIZE=50
STORAGE_CLEANUP_ENABLED=true
STORAGE_CLEANUP_INTERVAL_MS=21600000
STORAGE_CLEANUP_OLDER_THAN_HOURS=24
# Optional Storage backup settings for scripts/backup-supabase-storage.mjs.
# STORAGE_BACKUP_DATABASE_URL=postgresql://postgres:<db-password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
# STORAGE_BACKUP_ROOT=~/ajowa-storage-backups
# STORAGE_BACKUP_BUCKETS=resident-documents,payment-proofs,receipts,qr-images,finance-attachments,ticket-attachments,notice-attachments,report-exports
# STORAGE_BACKUP_CONCURRENCY=4
WHATSAPP_PROVIDER=
WHATSAPP_API_URL=
WHATSAPP_API_KEY=
WHATSAPP_SENDER_ID=
WHATSAPP_NOTIFICATIONS_ENABLED=false
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
PUSH_SUBJECT=mailto:admin@example.com
PUSH_NOTIFICATIONS_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=
APP_URL=https://ajowa.in
QR_SECRET=replace-with-a-long-random-secret
SOCIETY_CODE=AJOWA
